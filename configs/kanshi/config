# Kanshi configuration for automatic display management
# When only built-in display is connected (Samsung 1920x1200)
profile laptop {
    output eDP-1 enable scale 1.5
}

# Dell monitor via DP-2 - disable built-in
profile docked-dp2 {
    output "Dell Inc. DELL S2415H 7JK8G79D354L" enable mode 1920x1080@60
    output eDP-1 disable
}
